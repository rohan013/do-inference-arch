# Copy to config.env and fill in values before running provision scripts.
# cp provision/config.env.example provision/config.env

# DigitalOcean API token (or rely on doctl auth init).
# export DO_TOKEN="dop_v1_..."

# Cluster
CLUSTER_NAME=inference-cluster
CLUSTER_REGION=nyc3
CLUSTER_VERSION=1.32.2-do.0
# Standard pool for router, Redis, Prometheus, Grafana
SYSTEM_NODE_SIZE=s-4vcpu-8gb
SYSTEM_NODE_COUNT=2

# GPU node pools — verify slugs: doctl kubernetes options sizes
# Label applied to nodes: inference.do/pool=prefill|decode
PREFILL_POOL_NAME=prefill-h200
PREFILL_NODE_SIZE=gpu-h200x8
PREFILL_NODE_COUNT=1
DECODE_POOL_NAME=decode-mi300x
DECODE_NODE_SIZE=gpu-mi300x8
DECODE_NODE_COUNT=1

# Object storage (BF16 weight fallback)
SPACES_REGION=nyc3
SPACES_BUCKET=do-inference-weights
MODEL_PREFIX=models/llama-3.1-8b

# Block storage volumes for FP8 checkpoint cache (one per GPU node)
VOLUME_SIZE_GB=500
VOLUME_NAME_PREFIX=inference-checkpoint

# Container registry
DO_REGISTRY_NAME=inference
ROUTER_IMAGE=registry.digitalocean.com/inference/router:latest

# Smoke test
DEFAULT_MODEL=llama-3.1-8b
