# Copy and apply with a real token (never commit the filled file):
#   HF_TOKEN=dhf_... kubectl apply -f k8s/vllm/hf-secret.yaml
#
# Or use: ./provision/08-apply-hf-secret.sh
apiVersion: v1
kind: Secret
metadata:
  name: hf-token
  namespace: inference
  labels:
    app.kubernetes.io/part-of: do-agentic-inference
type: Opaque
stringData:
  token: "REPLACE_WITH_HUGGINGFACE_TOKEN"
